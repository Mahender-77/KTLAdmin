# =============================================================================
# KTL Admin (Vite) — copy to `.env` or `.env.local`
# =============================================================================

# API base URL (no trailing slash). Required for production builds.
# Development: if unset, falls back to http://localhost:5000
#
# Examples:
#   VITE_API_URL=http://localhost:5000
#   VITE_API_URL=https://api.example.com
#
VITE_API_URL=http://localhost:5000
